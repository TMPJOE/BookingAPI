# Environment variables for API Gateway

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8080

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Database
DB_URL=postgres://user:password@localhost:5432/bookingdb?sslmode=disable

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST=200

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_MAX_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=30s

# Upstream Services
BOOKING_SERVICE_URL=http://localhost:8081
ROOM_SERVICE_URL=http://localhost:8082
GUEST_SERVICE_URL=http://localhost:8083

# Authentication
AUTH_ENABLED=true
AUTH_TOKEN_EXPIRY=24h

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-Requested-With
CORS_ALLOW_CREDENTIALS=true